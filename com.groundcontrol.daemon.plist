<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.groundcontrol.daemon</string>
    <key>ProgramArguments</key>
    <array>
        <string>/Users/lukeroberts/ground-control/venv/bin/python</string>
        <string>/Users/lukeroberts/ground-control/scheduler.py</string>
    </array>
